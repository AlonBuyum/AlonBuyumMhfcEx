# Backend environment variables
# Copy this to .env and fill in real values for local dev

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=replace-with-a-64-char-random-hex-string

# Database (Postgres connection string)
# Local dev example: postgres://postgres:postgres@localhost:5432/crypto_advisor
# On Render: this is injected automatically when you link the DB to the web service
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crypto_advisor

# Frontend (for CORS allow-origin)
FRONTEND_URL=http://localhost:5173

# External APIs
CRYPTOPANIC_KEY=your-cryptopanic-api-key-here
